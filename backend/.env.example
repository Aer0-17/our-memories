# 服务器配置
PORT=8080

# 数据库
DATABASE_PATH=./data/ourMemories.db

# 静态前端目录。Docker 镜像中保持默认；从仓库根直接运行 dist/our-memories-api 时可设为 ./backend/public。
PUBLIC_DIR=./public

# JWT 密钥（⚠️ 生产环境必须修改！）
# 生成方式: openssl rand -base64 32
JWT_SECRET=your-secure-random-string-at-least-24-characters-long

# CORS 允许的来源（多个用逗号分隔）
ALLOWED_ORIGINS=http://localhost:3002,http://localhost:3003

# 仅填写 Lucky 实际连接后端时使用的精确 IP 或受限 CIDR；直连后端时留空。
TRUSTED_PROXIES=

# 默认空间配置（用于测试）
DEFAULT_SPACE_CODE=our-space-2026
DEFAULT_SPACE_NAME=回忆地图
DEFAULT_PASSWORD=
DEFAULT_USER_ME_DISPLAY_NAME=我
DEFAULT_USER_TA_DISPLAY_NAME=TA
LOGIN_PASSCODE_LENGTH=4
# false 时未登录接口不会公开真实空间名和成员姓名。
EXPOSE_LOGIN_PERSONALIZATION=false
AUTO_SEED=false

# 管理后台账号（设置后启动时自动创建/更新）
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=Admin User

# 对象存储配置（阿里云 OSS / AWS S3）
S3_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
S3_REGION=cn-hangzhou
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=our-memories
S3_PUBLIC_BASE_URL=https://your-cdn-domain.com
S3_OBJECT_ACL=public-read

# OSS 不可用时，后端会先把 data:image 图片落到本地目录；
# 后台任务会按间隔自动上传到 OSS 并更新数据库。
LOCAL_IMAGE_DIR=./data/images
PHOTO_SYNC_INTERVAL=10m

# 极光推送。Master Secret 只放后端环境变量，不要写进前端或 Android 包。
JPUSH_APP_KEY=
JPUSH_MASTER_SECRET=

# AI 文字润色（可选）
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# 默认纪念日配置（可选）
DEFAULT_ANNIVERSARY_DATE=
DEFAULT_ANNIVERSARY_LABEL=
