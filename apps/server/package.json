{
  "name": "@map-of-us/server",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "start:zeabur": "prisma migrate deploy && if [ \"$SEED_ON_START\" = \"true\" ]; then node dist/prisma/seed.js; fi && node dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.946.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.3.0",
    "@map-of-us/shared": "file:../../packages/shared",
    "@prisma/client": "^6.19.3",
    "argon2": "^0.44.0",
    "fastify": "^5.6.2",
    "nanoid": "^5.1.6",
    "prisma": "^6.19.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "vitest": "^4.0.15"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
