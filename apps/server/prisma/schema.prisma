generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SpacePlan {
  private
  pro
  team
}

enum SpaceStatus {
  active
  trialing
  past_due
  canceled
}

enum SpaceRole {
  owner
  member
}

enum DraftStatus {
  draft
  accepted
  rejected
}

enum AuxiliaryKind {
  favorite
  anniversary
  capsule
}

enum DraftKind {
  memory
  trip_plan
}

enum AiJobType {
  trip_plan
}

enum AiJobStatus {
  queued
  running
  needs_confirmation
  completed
  failed
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  displayName  String
  passwordHash String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  memberships  Membership[]
  memories     Memory[]     @relation("MemoryCreator")
  drafts       AiDraft[]
}

model Space {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  plan            SpacePlan        @default(private)
  status          SpaceStatus      @default(active)
  trialEndsAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  memberships     Membership[]
  memories        Memory[]
  settings        Setting[]
  cityAssets      CityAsset[]
  loginPhotos     LoginPhoto[]
  auxiliaryItems  AuxiliaryItem[]
  aiConversations AiConversation[]
  aiDrafts        AiDraft[]
  aiJobs          AiJob[]
  tripPlans       TripPlan[]
}

model Membership {
  id        String    @id @default(cuid())
  userId    String
  spaceId   String
  role      SpaceRole @default(member)
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  space     Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId])
  @@index([spaceId])
}

model Memory {
  id          String        @id @default(cuid())
  spaceId     String
  cityId      String
  city        String
  cityEn      String
  date        String
  text        String
  coverPhotoId String?
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  space       Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  createdBy   User?         @relation("MemoryCreator", fields: [createdById], references: [id], onDelete: SetNull)
  photos      MemoryPhoto[]

  @@index([spaceId, cityId])
  @@index([spaceId, createdAt])
}

model MemoryPhoto {
  id        String   @id @default(cuid())
  memoryId  String
  key       String
  url       String
  mimeType  String?
  width     Int?
  height    Int?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  memory    Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([memoryId])
}

model Setting {
  id        String   @id @default(cuid())
  spaceId   String
  key       String
  value     Json
  updatedAt DateTime @updatedAt
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([spaceId, key])
}

model CityAsset {
  id        String   @id @default(cuid())
  spaceId   String
  cityId    String
  key       String
  url       String
  mimeType  String?
  updatedAt DateTime @updatedAt
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([spaceId, cityId])
}

model LoginPhoto {
  id        String   @id @default(cuid())
  spaceId   String
  slotId    String
  key       String?
  url       String?
  text      Json?
  updatedAt DateTime @updatedAt
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([spaceId, slotId])
}

model AuxiliaryItem {
  id        String        @id @default(cuid())
  spaceId   String
  kind      AuxiliaryKind
  title     String
  date      String?
  note      String        @default("")
  cityId    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  space     Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId, kind])
}

model AiConversation {
  id                String    @id @default(cuid())
  spaceId           String
  userId            String?
  purpose           String
  astrbotSessionId  String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  space             Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([spaceId, purpose, astrbotSessionId])
}

model AiDraft {
  id        String      @id @default(cuid())
  spaceId   String
  userId    String?
  kind      DraftKind
  status    DraftStatus @default(draft)
  payload   Json
  source    Json?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  space     Space       @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([spaceId, kind, status])
}

model AiJob {
  id        String      @id @default(cuid())
  spaceId   String
  userId    String?
  type      AiJobType
  status    AiJobStatus @default(queued)
  input     Json
  result    Json?
  error     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  space     Space       @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId, type, status])
}

model TripPlan {
  id        String   @id @default(cuid())
  spaceId   String
  title     String
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId, createdAt])
}
