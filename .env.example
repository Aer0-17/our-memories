# Our Memories - Docker Compose configuration
# Copy this file to .env and fill all required values. Never commit .env.

OUR_MEMORIES_IMAGE=ghcr.io/aer0-17/our-memories:latest
GIN_MODE=release

# Security
# Generate with: openssl rand -base64 48
JWT_SECRET=
ALLOWED_ORIGINS=https://your-domain.example

# Exact reverse-proxy IPs/CIDRs only. Never use 0.0.0.0/0 or ::/0.
TRUSTED_PROXIES=
LOGIN_PASSCODE_LENGTH=4
EXPOSE_LOGIN_PERSONALIZATION=false

# Initial/private space. Keep AUTO_SEED=false when an existing database is used.
AUTO_SEED=false
DEFAULT_SPACE_CODE=our-space-2026
DEFAULT_PASSWORD=
DEFAULT_SPACE_NAME=回忆地图
DEFAULT_USER_ME_DISPLAY_NAME=我
DEFAULT_USER_TA_DISPLAY_NAME=TA
DEFAULT_ANNIVERSARY_DATE=
DEFAULT_ANNIVERSARY_LABEL=

# Admin account. Set username and password together. Password: at least 12 characters.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=Admin User

# Local image fallback and synchronization interval
PHOTO_SYNC_INTERVAL=10m

# Optional S3-compatible object storage
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=our-memories
S3_PUBLIC_BASE_URL=
S3_OBJECT_ACL=

# Optional JPush server credentials
JPUSH_APP_KEY=
JPUSH_MASTER_SECRET=

# Optional DeepSeek text polishing
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
