# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=4002
DATABASE_URL=postgresql://mapofus:mapofus@localhost:5432/mapofus?schema=public
JWT_SECRET=change-me-to-a-long-random-secret-at-least-24-chars
WEB_ORIGIN=http://localhost:3002
SEED_ON_START=false

# First private space and two initial users
DEFAULT_SPACE_NAME=我们的回忆
DEFAULT_SPACE_SLUG=our-memories
DEFAULT_USER_1_USERNAME=me
DEFAULT_USER_1_PASSWORD=1234
DEFAULT_USER_1_DISPLAY_NAME=Me
DEFAULT_USER_2_USERNAME=her
DEFAULT_USER_2_PASSWORD=1234
DEFAULT_USER_2_DISPLAY_NAME=Her

# Admin panel account. Set these in production to auto-create/update the admin login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
ADMIN_DISPLAY_NAME=Admin User

# Anniversary date (format: YYYY.MM.DD)
DEFAULT_ANNIVERSARY_DATE=2026.03.20
DEFAULT_ANNIVERSARY_LABEL=我们在一起

# S3-compatible object storage. For local docker-compose MinIO:
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=mapofus
S3_SECRET_ACCESS_KEY=mapofus-secret
S3_BUCKET=our-memories
S3_PUBLIC_BASE_URL=http://localhost:9000/our-memories
S3_OBJECT_ACL=

# DeepSeek API for AI text polishing
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# WeChat mini program login/binding. Leave empty until the mini program is registered.
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=

# Web build
NEXT_PUBLIC_API_BASE_URL=http://localhost:4002

# Android online APK. The APK will load this hosted web app directly.
# Keep it as https in production, then run:
# CAPACITOR_SERVER_URL=https://your-domain.com npm run mobile:android:build:online
CAPACITOR_SERVER_URL=

# Optional override for separated frontend/backend deployments.
# Leave empty for same-origin deployments where /api/v1 is served by the same domain.
# NEXT_PUBLIC_API_BASE_URL=https://your-api-domain.com
