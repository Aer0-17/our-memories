{
  "name": "our-memories",
  "version": "0.2.0",
  "description": "Online-first private couple memory map and anniversary wall",
  "author": "回忆地图",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @map-of-us/web",
    "dev:web": "npm run dev -w @map-of-us/web",
    "dev:server": "cd backend && go run main.go",
    "build": "npm run build:shared && npm run build -w @map-of-us/web && npm run build -w @map-of-us/admin && npm run build:server",
    "build:shared": "npm run build -w @map-of-us/shared",
    "build:web": "npm run build:shared && npm run build -w @map-of-us/web",
    "build:admin": "npm run build -w @map-of-us/admin",
    "build:server": "cd backend && go build -o ../dist/our-memories-api ./main.go",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run build:shared && npm run typecheck --workspaces --if-present",
    "desktop": "npm run desktop -w @map-of-us/desktop",
    "dist:dir": "npm run dist:dir -w @map-of-us/desktop",
    "dist:win": "npm run dist:win -w @map-of-us/desktop",
    "mobile:sync": "npm run sync -w @map-of-us/mobile",
    "mobile:android:sync": "npm run android:sync -w @map-of-us/mobile",
    "mobile:android:build": "npm run android:build -w @map-of-us/mobile",
    "mobile:android:sync:online": "npm run android:sync:online -w @map-of-us/mobile",
    "mobile:android:build:online": "npm run android:build:online -w @map-of-us/mobile",
    "miniprogram:dev": "npm run dev:weapp -w @map-of-us/miniprogram",
    "miniprogram:build": "npm run build:weapp -w @map-of-us/miniprogram",
    "map:geo": "node scripts/build-map-geo.mjs",
    "db:generate": "echo \"Go/SQLite backend does not require generated DB client\"",
    "db:migrate": "cd backend && go run ./cmd/migrate",
    "db:seed": "cd backend && AUTO_SEED=true go run ./cmd/migrate"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^20",
    "eslint": "^9",
    "typescript": "^5"
  },
  "dependencies": {
    "swr": "^2.4.1"
  }
}
